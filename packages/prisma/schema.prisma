// ============================================================
// M2 SCHEMA FRAGMENT — Vehicle Management
// ------------------------------------------------------------
// This is NOT a standalone schema. It is the M2 slice of the
// single shared prisma/schema.prisma the whole team edits together.
//
// HOW TO USE THIS FILE:
// 1. Open the team's real prisma/schema.prisma (should already exist
//    on `dev` if the Day-1 schema call happened).
// 2. Copy the "generator" / "datasource" blocks ONLY IF they don't
//    already exist there.
// 3. Copy the Vehicle, VehicleDocument, Reminder, DocumentType blocks
//    below into the shared schema.
// 4. Add the one line marked "ADD TO USER MODEL" into M1's User model.
// 5. Run: npx prisma format && npx prisma migrate dev --name add-vehicle-models
// 6. Announce in the group chat before pushing, per the guide's Golden Rule.
//
// If the team hasn't written schema.prisma yet, this whole file can be
// used as-is to bootstrap it (it includes a minimal User stub so the
// schema is valid on its own — replace that stub with M1's real User
// model as soon as it exists).
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Neon (Postgres)
  url      = env("DATABASE_URL")
}

// ---- Minimal placeholder, owned by M1 — replace with the real
// ---- Identity/Access model. Kept here only so this file is runnable
// ---- standalone during Sprint 0 bootstrapping.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())

  // ADD TO USER MODEL (M2 relation):
  vehicles  Vehicle[]
}

enum Role {
  CUSTOMER
  MECHANIC
  GARAGE_OWNER
  ADMIN
}

// ============================================================
// M2 — Vehicle Management
// ============================================================

model Vehicle {
  id           String   @id @default(cuid())
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  make         String
  model        String
  year         Int
  licensePlate String   @unique
  vin          String?  @unique
  color        String?
  mileage      Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  documents    VehicleDocument[]
  reminders    Reminder[]

  @@index([ownerId])
}

enum DocumentType {
  REGISTRATION
  INSURANCE
  IMAGE
  OTHER
}

model VehicleDocument {
  id         String       @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  type       DocumentType
  fileName   String
  fileUrl    String
  mimeType   String
  sizeBytes  Int

  uploadedAt DateTime     @default(now())

  @@index([vehicleId])
}

model Reminder {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  title     String
  dueDate   DateTime
  completed Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([vehicleId])
}
