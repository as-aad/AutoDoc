datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  MECHANIC
  GARAGE_OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   @default("password123")
  role      Role     @default(CUSTOMER)
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())

  vehicles         Vehicle[]
  bookings         ServiceBooking[]  @relation("CustomerBookings")
  reviews          Review[]          @relation("CustomerReviews")
  managedGarage    Garage?           @relation("GarageOwner")
  mechanicProfile  Mechanic?
}

model Garage {
  id          String   @id @default(uuid())
  name        String
  address     String
  phone       String
  image       String?
  rating      Float    @default(5.0)
  totalReviews Int     @default(0)
  ownerId     String?  @unique
  owner       User?    @relation("GarageOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())

  mechanics Mechanic[]
  bookings  ServiceBooking[]
  reviews   Review[]
}

model Mechanic {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  garageId       String
  garage         Garage   @relation(fields: [garageId], references: [id])
  specialization String
  rating         Float    @default(5.0)
  totalReviews   Int      @default(0)
  createdAt      DateTime @default(now())

  bookings ServiceBooking[]
  reviews  Review[]
}

model Vehicle {
  id             String   @id @default(uuid())
  customerId     String
  customer       User     @relation(fields: [customerId], references: [id])
  make           String
  model          String
  year           Int
  vin            String   @unique
  licensePlate   String
  currentMileage Int
  healthScore    Int      @default(95)
  image          String?
  lastServicedAt DateTime?
  createdAt      DateTime @default(now())

  bookings ServiceBooking[]
  reports  MaintenanceReport[]
}

model ServiceBooking {
  id               String        @id @default(uuid())
  vehicleId        String
  vehicle          Vehicle       @relation(fields: [vehicleId], references: [id])
  customerId       String
  customer         User          @relation("CustomerBookings", fields: [customerId], references: [id])
  garageId         String
  garage           Garage        @relation(fields: [garageId], references: [id])
  mechanicId       String?
  mechanic         Mechanic?     @relation(fields: [mechanicId], references: [id])
  serviceType      String
  description      String
  status           BookingStatus @default(PENDING)
  cost             Float?
  mileageAtService Int?
  scheduledDate    DateTime      @default(now())
  completedAt      DateTime?
  createdAt        DateTime      @default(now())

  review Review?
  report MaintenanceReport?
}

model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  booking     ServiceBooking @relation(fields: [bookingId], references: [id])
  customerId  String
  customer    User     @relation("CustomerReviews", fields: [customerId], references: [id])
  garageId    String
  garage      Garage   @relation(fields: [garageId], references: [id])
  mechanicId  String?
  mechanic    Mechanic? @relation(fields: [mechanicId], references: [id])
  
  garageRating   Int      // 1 - 5 stars for garage
  mechanicRating Int?     // 1 - 5 stars for mechanic
  comment        String
  createdAt      DateTime @default(now())
}

model MaintenanceReport {
  id                 String   @id @default(uuid())
  vehicleId          String
  vehicle            Vehicle  @relation(fields: [vehicleId], references: [id])
  bookingId          String?  @unique
  booking            ServiceBooking? @relation(fields: [bookingId], references: [id])
  
  overallHealthScore Int      // 0 - 100%
  summary            String
  systemHealthJson   String   // JSON string of { engine, brakes, transmission, suspension, electrical, fluids }
  replacedPartsJson  String   // JSON string of [{ name, partNumber, cost, warranty }]
  mechanicNotes      String
  createdAt          DateTime @default(now())
}
