# Copy this to apps/api/.env and fill in your own values.
# Never commit the real .env file.

# Get this from your Neon project: console.neon.tech -> Connection Details
# Use the "Pooled connection" string, and make sure ?sslmode=require is included.
DATABASE_URL="postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require"

PORT=4000

# Where uploaded vehicle documents/images are stored locally in dev
UPLOAD_DIR="./uploads/vehicles"
